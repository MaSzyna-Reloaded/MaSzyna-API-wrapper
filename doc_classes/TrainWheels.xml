<?xml version="1.0" encoding="UTF-8" ?>
<class name="TrainWheels" inherits="TrainPart" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		Class used to configure wheel geometry and expose wheel-related runtime state.
	</brief_description>
	<description>
		Class that maps the [code]Wheels[/code] section of MaSzyna vehicle configuration to the internal mover.
	</description>
	<tutorials>
	</tutorials>
	<members>
		<member name="axle_arrangement" type="String" setter="set_axle_arrangement" getter="get_axle_arrangement" default="">
			[code]Wheels:Axle[/code]
			Axle arrangement string, for example [code]Bo'Bo'[/code].
		</member>
		<member name="axle_inertial_moment" type="float" setter="set_axle_inertial_moment" getter="get_axle_inertial_moment" default="0.0">
			[code]Wheels:AIM[/code]
			Wheelset inertial moment.
		</member>
		<member name="bearing_type" type="int" setter="set_bearing_type" getter="get_bearing_type" default="1">
			[code]Wheels:BearingType[/code]
			Bearing type used by the vehicle.
		</member>
		<member name="bogie_axle_spacing" type="float" setter="set_bogie_axle_spacing" getter="get_bogie_axle_spacing" default="0.0">
			[code]Wheels:Ad[/code]
			Distance between axles on a bogie.
		</member>
		<member name="bogie_pivot_spacing" type="float" setter="set_bogie_pivot_spacing" getter="get_bogie_pivot_spacing" default="0.0">
			[code]Wheels:Bd[/code]
			Distance between bogie pivots, or axle spacing for non-bogie vehicles.
		</member>
		<member name="front_rolling_wheel_diameter" type="float" setter="set_front_rolling_wheel_diameter" getter="get_front_rolling_wheel_diameter" default="0.0">
			[code]Wheels:Dl[/code]
			Diameter of the front rolling wheels. When unset, the powered wheel diameter is used.
		</member>
		<member name="minimum_curve_radius" type="float" setter="set_minimum_curve_radius" getter="get_minimum_curve_radius" default="0.0">
			[code]Wheels:Rmin[/code]
			Minimum supported curve radius stored in wrapper configuration.
		</member>
		<member name="powered_wheel_diameter" type="float" setter="set_powered_wheel_diameter" getter="get_powered_wheel_diameter" default="0.0">
			[code]Wheels:D[/code]
			Diameter of the powered wheels.
		</member>
		<member name="rear_rolling_wheel_diameter" type="float" setter="set_rear_rolling_wheel_diameter" getter="get_rear_rolling_wheel_diameter" default="0.0">
			[code]Wheels:Dt[/code]
			Diameter of the rear rolling wheels. When unset, the powered wheel diameter is used.
		</member>
		<member name="track_width" type="float" setter="set_track_width" getter="get_track_width" default="1.435">
			[code]Wheels:Tw[/code]
			Nominal track width in meters.
		</member>
	</members>
	<constants>
		<constant name="BEARING_TYPE_SLIDE" value="0" enum="BearingType">
		</constant>
		<constant name="BEARING_TYPE_ROLL" value="1" enum="BearingType">
		</constant>
	</constants>
</class>
