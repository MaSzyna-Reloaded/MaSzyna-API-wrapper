<?xml version="1.0" encoding="UTF-8" ?>
<class name="MaszynaMaterial" inherits="RefCounted" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		Stores parsed MaSzyna material data.
	</brief_description>
	<description>
		[MaszynaMaterial] holds material properties parsed from a MaSzyna [code].mat[/code] file, including texture paths, transparency mode, shader name and shadow rank. It can apply the supported subset of those settings to a [StandardMaterial3D].
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="apply_to_material" qualifiers="const">
			<return type="void" />
			<param index="0" name="material" type="StandardMaterial3D" />
			<description>
				Applies the stored material settings to the provided [StandardMaterial3D].
			</description>
		</method>
	</methods>
	<members>
		<member name="albedo_texture_path" type="String" setter="set_albedo_texture_path" getter="get_albedo_texture_path" default="&quot;&quot;">
			Resolved albedo texture path.
		</member>
		<member name="autumn_albedo_texture_path" type="String" setter="set_autumn_albedo_texture_path" getter="get_autumn_albedo_texture_path" default="&quot;&quot;">
			Resolved autumn albedo texture path.
		</member>
		<member name="normal_texute_path" type="String" setter="set_normal_texute_path" getter="get_normal_texute_path" default="&quot;&quot;">
			Resolved normal map texture path.
		</member>
		<member name="shader" type="String" setter="set_shader" getter="get_shader" default="&quot;&quot;">
			Parsed shader name from the material definition.
		</member>
		<member name="shadow_rank" type="int" setter="set_shadow_rank" getter="get_shadow_rank" default="0">
			Parsed shadow priority value.
		</member>
		<member name="transparency" type="int" setter="set_transparency" getter="get_transparency" default="0">
			Stored Godot transparency mode derived from the material definition.
		</member>
		<member name="winter_albedo_texture_path" type="String" setter="set_winter_albedo_texture_path" getter="get_winter_albedo_texture_path" default="&quot;&quot;">
			Resolved winter albedo texture path.
		</member>
		<member name="winter_normal_texute_path" type="String" setter="set_winter_normal_texute_path" getter="get_winter_normal_texute_path" default="&quot;&quot;">
			Resolved winter normal map texture path.
		</member>
	</members>
</class>
